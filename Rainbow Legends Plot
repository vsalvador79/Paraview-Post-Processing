# Python Script to emulate rainbow colormap
# Copy and paste this entire script into ParaView's Script Editor

import paraview.simple as pvs

# Get the active source
active_source = pvs.GetActiveSource()

if active_source:
    # Get the display properties
    display = pvs.GetDisplayProperties(active_source)
    
    if display:
        # Get the color array name
        color_array = display.ColorArrayName
        
        if color_array and color_array[0] != '':
            # Get the color transfer function
            lut = pvs.GetColorTransferFunction(color_array[1])
            
            # Clear existing points
            lut.RGBPoints = []
            
            # Set classic rainbow colors REVERSED (Blue to Red)
            # Blue at bottom (low values), Red at top (high values)
            lut.RGBPoints = [
                0.0, 0.0, 0.0, 1.0,      # Blue (low values)
                0.16, 0.0, 0.5, 1.0,     # Blue-Cyan
                0.33, 0.0, 1.0, 1.0,     # Cyan
                0.5, 0.0, 1.0, 0.0,      # Green
                0.66, 1.0, 1.0, 0.0,     # Yellow
                0.83, 1.0, 0.5, 0.0,     # Orange
                1.0, 1.0, 0.0, 0.0       # Red (high values)
            ]
            
            # Use RGB interpolation for classic rainbow
            lut.ColorSpace = 'RGB'
            
            # Update the view
            view = pvs.GetActiveView()
            if view:
                pvs.Render(view)
            
            print("✓ Classic rainbow color map applied (Blue to Red)!")
            print(f"  Applied to: {color_array[1]}")
            print("  Blue = low values, Red = high values")
        else:
            print("⚠ No color array selected. Please color by a scalar field first.")
    else:
        print("⚠ Could not get display properties.")
else:
    print("⚠ No active source found. Please load data first.")

